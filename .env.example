# Copy to .env and fill in your values
# cp .env.example .env

# Absolute path to your library folder on the host
LIBRARY_PATH=/path/to/your/manga

# Port exposed on the host (default: 8000)
PORT=8000

# ComicVine API key — free at https://comicvine.gamespot.com/api/
# Leave empty to disable ComicVine scraping
COMICVINE_API_KEY=
