# BookLibrary — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Priority: .env values always override UI settings.
# Once set here, these values cannot be changed from the Settings page.

# ── Library ──────────────────────────────────────────────────────────────────

# Absolute path to the folder containing your manga, comics, and ebooks.
# Supports CBZ, CBR, EPUB, PDF, MOBI, AZW3.
LIBRARY_PATH=/path/to/your/library

# ── Scan folder filtering ────────────────────────────────────────────────────
# Filter applies to 1st-level subdirectories of LIBRARY_PATH only.
# SCAN_EXCLUDE always wins over SCAN_INCLUDE.
# You can also drop a .scanignore file at the library root (one folder per line).

# Whitelist: scan ONLY these folders (comma-separated folder names).
# Leave empty or omit to scan everything (default).
# SCAN_INCLUDE=Manga,BD,Webtoons

# Blacklist: never scan these folders (comma-separated folder names).
# SCAN_EXCLUDE=Downloads,Inbox,_unsorted

# ── Server ───────────────────────────────────────────────────────────────────

# TCP port for the web interface (default: 8000)
PORT=8000

# Enable debug mode: activates /debug endpoint, /docs (Swagger UI),
# and auto-reload on file changes. Do NOT enable in production.
# DEBUG=true

# ── Permissions (Docker only) ─────────────────────────────────────────────
# UID and GID of the host user who owns your library and data directories.
# Run `id -u` and `id -g` on the host to find the right values.
# Default: 1000:1000 (standard first user on most Linux/NAS systems)
# PUID=1000
# PGID=1000

# ── Metadata API keys ────────────────────────────────────────────────────────

# ComicVine — comics and manga metadata
# Free key at: https://comicvine.gamespot.com/api/
# COMICVINE_API_KEY=

# Hardcover — book metadata
# Free key at: https://hardcover.app/account/api
# HARDCOVER_API_KEY=

# ── Custom categories ────────────────────────────────────────────────────────
# Custom categories are managed from the Settings UI (GET/POST/PATCH/DELETE
# /config/categories) and persisted in data/config.json.
#
# They cannot be defined via env vars because they are structured objects
# (name, label, folders, color). Use the UI or edit config.json directly.
#
# Built-in categories (always available, cannot be deleted):
#   manga    — matched by folder keywords: manga, mangas, manhwa, manhua, webtoon…
#   comics   — matched by folder keywords: comics, bd, bandes dessinees, marvel…
#   book     — matched by folder keywords: books, novels, roman, ebooks, livres…
#   unknown  — fallback when no rule matches
#
# Example custom category (add via UI or config.json):
#   { "name": "light-novel", "label": "Light novels",
#     "folders": ["LN", "Light Novels"], "color": "#7F77DD" }
